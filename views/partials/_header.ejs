<!-- ══════════ HEADER ══════════ -->
<header class="sticky top-0 z-50 bg-cod-dark/95 backdrop-blur border-b border-cod-border px-6 py-4" @click.stop>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-6">
      <h1 class="text-2xl font-bold tracking-tight text-white">Retroplanning Album</h1>
      <div class="flex items-center gap-3" x-show="tasks.length > 0">
        <div class="w-48 h-3 bg-cod-card rounded-full overflow-hidden">
          <div class="h-full rounded-full progress-bar"
               :class="globalProgress === 100 ? 'bg-cod-green' : 'bg-cod-accent'"
               :style="'width:' + globalProgress + '%'"></div>
        </div>
        <span class="text-base font-bold text-white" x-text="globalProgress + '%'"></span>
      </div>
    </div>
    <div class="flex items-center gap-4">
      <template x-if="releaseDate">
        <div class="text-right text-base">
          <span class="text-cod-accent font-semibold" x-text="formattedReleaseDate"></span>
          <span class="text-cod-muted mx-1">—</span>
          <span class="font-mono" :class="daysLeft < 30 ? 'text-cod-red' : daysLeft < 90 ? 'text-cod-orange' : 'text-cod-green'"
                x-text="'J-' + daysLeft"></span>
        </div>
      </template>
    </div>
  </div>
</header>
