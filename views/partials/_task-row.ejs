<%# Single task row — rendered inside x-for="task in phaseTasks(phase.id)" %>
<div class="flex items-start gap-4 rounded px-3 py-3 transition group cursor-pointer task-row"
     :class="{
       'opacity-40': task.done,
       'bg-cod-accent/5': editingTask === task.id,
       'hover:bg-cod-card/50': editingTask !== task.id
     }"
     @click="if (editingTask !== task.id) { if (!guardedCancelAllEditing()) return; editingTask = task.id; editTaskData = JSON.parse(JSON.stringify(task)); }">

  <!-- Checkbox -->
  <button @click.stop="toggleTask(task)" class="custom-check mt-1" :class="task.done ? 'checked' : ''">
    <svg class="check-icon w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
  </button>

  <div class="flex-1 min-w-0">
    <!-- Task text: span in read mode, input in edit mode -->
    <div class="flex items-center gap-2">
      <span x-show="editingTask !== task.id" class="text-base font-medium" :class="task.done ? 'line-through' : ''" x-text="task.text"></span>
      <template x-if="editingTask !== task.id && (task.contributors || []).length > 0">
        <div class="flex items-center gap-1 ml-1">
          <template x-for="name in (task.contributors || [])" :key="name">
            <%- include('_contributor-badge') %>
          </template>
        </div>
      </template>
      <input x-show="editingTask === task.id" type="text" x-model="editTaskData.text" @click.stop
             @keydown.enter="saveTask(task.id)"
             class="text-base bg-transparent border-b border-cod-accent/40 outline-none w-full py-0.5 text-cod-text focus:border-cod-accent transition-colors">
    </div>

    <!-- Notes: markdown in read mode, textarea in edit mode -->
    <div x-show="editingTask !== task.id && task.notes && !task.done"
         class="text-sm text-cod-muted mt-1.5 pl-3 border-l-2 border-cod-border/50 markdown-body"
         x-html="renderMarkdown(task.notes)"></div>
    <textarea x-show="editingTask === task.id" x-model="editTaskData.notes" placeholder="Notes (markdown)" @click.stop
              @keydown.ctrl.enter="saveTask(task.id)" @keydown.meta.enter="saveTask(task.id)"
              x-effect="if (editingTask === task.id) $nextTick(() => { let el = $el; el.style.height = 'auto'; el.style.height = Math.max(el.scrollHeight, 32) + 'px' })"
              @input="$el.style.height = 'auto'; $el.style.height = $el.scrollHeight + 'px'"
              rows="1"
              class="text-sm bg-transparent border border-cod-border/60 rounded outline-none w-full py-1.5 px-2 mt-1 text-cod-muted focus:border-cod-accent/40 transition-colors resize-y"></textarea>

    <!-- Decision pills: read mode -->
    <template x-if="editingTask !== task.id">
      <div class="pl-3 mt-1">
        <template x-for="(dec, di) in (task.decisions || [])" :key="'dn'+di">
          <div class="relative mt-1" x-show="!task.done" x-data="{ menuOpen: false }" @click.stop>
            <button @click="menuOpen = !menuOpen"
                    class="text-sm cursor-pointer flex items-center gap-1.5 rounded px-2.5 py-1 border transition"
                    :class="{
                      'bg-cod-accent/15 text-cod-accent border-cod-accent/30': dec.status === 'open',
                      'bg-cod-blue/15 text-cod-blue border-cod-blue/30': dec.status === 'discussed',
                      'bg-cod-green/15 text-cod-green border-cod-green/30': dec.status === 'decided'
                    }">
              <span x-text="decisionIcon(dec.status)"></span>
              <span x-text="dec.notes || 'Décision ' + (di+1)"></span>
            </button>
            <%- include('_decision-dropdown', { clickAction: "updateTaskDecision(task, di, opt.v); menuOpen = false" }) %>
          </div>
        </template>
      </div>
    </template>

    <!-- Decision pills: edit mode -->
    <template x-if="editingTask === task.id">
      <div @click.stop>
        <template x-for="(dec, di) in (editTaskData.decisions || [])" :key="'de'+di">
          <div class="relative mt-1" x-data="{ menuOpen: false }">
            <div class="flex items-center gap-2">
              <button @click="menuOpen = !menuOpen"
                      class="text-sm cursor-pointer flex items-center gap-1.5 rounded px-2.5 py-1 border transition shrink-0"
                      :class="{
                        'bg-cod-accent/15 text-cod-accent border-cod-accent/30': dec.status === 'open',
                        'bg-cod-blue/15 text-cod-blue border-cod-blue/30': dec.status === 'discussed',
                        'bg-cod-green/15 text-cod-green border-cod-green/30': dec.status === 'decided'
                      }">
                <span x-text="decisionIcon(dec.status)"></span>
                <span x-text="decisionLabel(dec.status)"></span>
              </button>
              <input type="text" x-model="editTaskData.decisions[di].notes" placeholder="Notes décision"
                     @keydown.enter="saveTask(task.id)"
                     class="flex-1 text-sm bg-transparent border-b border-cod-border/60 outline-none py-0.5 text-cod-muted focus:border-cod-accent/40 transition-colors">
              <button @click="editTaskData.decisions.splice(di, 1)"
                      class="text-cod-muted hover:text-cod-red text-sm px-1" title="Supprimer la décision">✕</button>
            </div>
            <%- include('_decision-dropdown', { clickAction: "editTaskData.decisions[di].status = opt.v; menuOpen = false" }) %>
          </div>
        </template>
        <button @click="editTaskData.decisions = [...(editTaskData.decisions || []), { status: 'open', notes: '' }]"
                class="text-sm text-cod-accent hover:text-cod-accent/80 mt-1.5">+ Décision</button>
      </div>
    </template>

    <!-- Contributor assignment (edit mode, auto-saves on click) -->
    <template x-if="editingTask === task.id && contributors.length > 0">
      <div class="flex items-center gap-1.5 mt-2 flex-wrap" @click.stop>
        <span class="text-xs text-cod-muted">Qui :</span>
        <template x-for="contrib in contributors" :key="contrib.name">
          <button @click="toggleContributor(task, contrib.name)"
                  class="text-xs px-2 py-0.5 rounded-full border transition"
                  :class="!(task.contributors || []).includes(contrib.name) ? 'text-cod-muted border-cod-border' : ''"
                  :style="(task.contributors || []).includes(contrib.name) ? contributorStyle(contrib.name, true) : ''">
            <span x-text="contrib.name"></span>
          </button>
        </template>
      </div>
    </template>
  </div>

  <!-- Date + action buttons -->
  <div class="shrink-0 flex items-center gap-2" @click.stop>
    <span x-show="editingTask !== task.id" class="text-sm font-mono"
          :class="task.done ? 'text-cod-muted' : taskUrgencyColor(task)"
          x-text="formatDate(task.deadlineDate)"></span>
    <input x-show="editingTask === task.id" type="date" x-model="editTaskData.deadlineDate"
           class="text-sm bg-transparent border-b border-cod-accent/40 outline-none py-0.5 text-cod-text font-mono focus:border-cod-accent transition-colors">

    <!-- Action buttons (edit mode only) -->
    <template x-if="editingTask === task.id">
      <div class="flex items-center gap-1 ml-2">
        <button @click="saveTask(task.id)" class="text-cod-muted hover:text-cod-green p-2 rounded-full hover:bg-cod-green/10 transition-colors" title="Enregistrer">
          <%- icon('check', 'lg') %>
        </button>
        <button @click.stop="guardedCancelAllEditing()" class="text-cod-muted hover:text-white p-2 rounded-full hover:bg-cod-border/50 transition-colors" title="Annuler">
          <%- icon('cancel', 'lg') %>
        </button>
        <%- include('_delete-confirm', { deleteKey: "task.id", deleteAction: "deleteTask(task.id)", confirmTitle: "Confirmer la suppression", size: "lg" }) %>
      </div>
    </template>
  </div>
</div>
